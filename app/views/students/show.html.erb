<h1>Detalhes do Aluno: <%= @student.name %></h1>

<p><strong>Matrícula:</strong> <%= @student.registration %></p>
<p><strong>CPF:</strong> <%= @student.cpf %></p>
<p><strong>E-mail:</strong> <%= @student.email %></p>
<p><strong>Curso:</strong> <%= @student.course %></p>

<div style="float: left; margin-left: 20px;">
  <% if @student.qr_code_hash.present? %>
    <h2>QR Code de Acesso</h2>
    <%= @student.generate_qr_code_svg %>
    <p class="text-center">Chave: <code><%= @student.qr_code_hash %></code></p>
  <% else %>
    <p>QR Code ainda não gerado. Edite e salve para forçar a geração.</p>
  <% end %>
  <% if current_user.role&.name == 'admin' %>
  <%= link_to 'Gerar Novo QR Code', regenerate_qr_student_path(@student), 
      data: { turbo_method: :post, turbo_confirm: 'Isso invalidará o QR Code antigo. Continuar?' },
      style: "color: orange;" %>
<% end %>

</div>

<hr style="clear: both;">

<%= link_to 'Editar', edit_student_path(@student) %> |
<%= link_to 'Voltar para a Lista', students_path %>
